{
  "name": "discord-neo4j-project-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord AI project-manager bot with Neo4j structured meeting memory.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "neo4j:migrate": "tsx scripts/run-migrations.ts",
    "discord:register": "tsx scripts/register-commands.ts",
    "sample:ingest": "tsx scripts/ingest-sample.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@discordjs/rest": "^2.4.2",
    "@discordjs/voice": "^0.19.2",
    "discord-api-types": "^0.37.115",
    "discord.js": "^14.17.3",
    "dotenv": "^16.4.7",
    "neo4j-driver": "^5.27.0",
    "prism-media": "^1.3.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
