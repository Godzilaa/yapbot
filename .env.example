DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Local Neo4j uses bolt://localhost:7687.
# Neo4j Aura/cloud usually provides a neo4j+s://... URI.
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

TRANSCRIPT_STORAGE_PATH=./transcripts
LOW_CONFIDENCE_THRESHOLD=0.7

# Use stub for local graph testing. Use openai-compatible for real LLM extraction.
LLM_PROVIDER=stub
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_MS=60000
